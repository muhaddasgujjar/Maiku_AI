# Maiku AI — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# === Backend Server ===
BACKEND_HOST=localhost
BACKEND_PORT=8765

# === AI Models (Groq) ===
# STT model — Groq Whisper
STT_MODEL=whisper-large-v3

# LLM model — use llama3-8b-8192 during dev (higher free quota)
# Switch to llama-3.3-70b-versatile for better quality in prod
LLM_MODEL=llama-3.1-8b-instant

# === Storage ===
CHROMA_PERSIST_DIR=./backend/chroma_db

# === Audio (Phase 2) ===
# Set to name of your audio output device for WASAPI loopback
# Leave empty to auto-detect default output device
AUDIO_DEVICE_NAME=
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=5
